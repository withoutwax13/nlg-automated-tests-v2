{
  "compilerOptions": {
    "target": "es5",
    "lib": [
      "es2015",
      "dom",
      "es2016"
    ],
    "types": [
      "node",
      "@playwright/test"
    ],
    "esModuleInterop": true,
    "ignoreDeprecations": "6.0",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "strict": false
  },
  "include": [
    "playwright/**/*.ts"
  ],
  "exclude": [
    "playwright/e2e/Accessibility/**",
    "playwright/e2e/Approvals/**"
  ]
}
