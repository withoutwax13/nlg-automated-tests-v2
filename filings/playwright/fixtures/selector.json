{
    "governmentSearchBar": "input[placeholder='Search government ...']",
    "governmentList": "ul > li[role='option']",
    "approvalHeading": "h1",
    "startWorkflowLink": ".NLG-Hyperlink",
    "modalAppvoralButton": ".NLGButtonPrimary",
    "modalRejectButton": ".my-3 > .NLGButtonSecondary",
    "checkBox": "[aria-rowindex='2'] > .k-grid-content-sticky",
    "tableHeader": ".k-grid-header",
    "tableBody": "table[class='k-table k-grid-table k-table-md']",
    "tablePager": ".k-pager",
    "setNumbersonGrid": ".k-input-value-text",
    "checkGridDataNumber": "table[class='k-table k-grid-table k-table-md']  > tbody > tr",
    "tableRow": "table[class='k-table k-grid-table k-table-md'] > tbody > tr:eq(${index})",
    "cellSelector": "td:nth-child(6), th:nth-child(6)",
    "iconSelector": "[aria-rowindex=\"${ariaRowIndex}\"] > [aria-colindex=\"3\"] > .d-flex > .fa-solid", 
    "modalSelector": ".k-window",
    "exportButton": ".CustomCsvLink > .NLGButtonSecondary", 
    "startAllApproval": ".NLG-ButtonsContainer.d-flex > .NLG-ButtonsContainer > :nth-child(1",
    "checkMultipleIndex": "[aria-rowindex=\"${rowIndex}\"] > .k-grid-content-sticky"
}