{
  "compilerOptions": {
    "target": "es2015",
    "lib": [
      "es2016",
      "dom",
      "es2017"
    ],
    "types": [
      "node",
      "@playwright/test"
    ],
    "esModuleInterop": true,
    "ignoreDeprecations": "5.0",
    "resolveJsonModule": true,
    "module": "commonjs",
    "skipLibCheck": true,
    "noImplicitAny": false,
    "strict": false
  },
  "include": [
    "playwright/**/*.ts"
  ]
}
