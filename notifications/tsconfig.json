{
    "compilerOptions": {
        "target": "es5",
        "lib": ["es2015", "dom"],
        "types": ["node", "@playwright/test"],
        "strict": true,
        "baseUrl": "../node_modules",
        "outDir": "../dist/out-tsc",
        // "sourceMap": true,
        "declaration": false,
        "downlevelIteration": true,
        "experimentalDecorators": true,
        "moduleResolution": "node",
        "importHelpers": true,
        "module": "commonjs",
        "esModuleInterop": true,
        "resolveJsonModule": true,
    },
    "include": [
        "**/*.ts"
    ]
}